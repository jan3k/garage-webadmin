{
	"extends": "@tsconfig/node24/tsconfig.json",
	"include": [
		"vite.config.*",
		"vitest.config.*",
		"cypress.config.*",
		"nightwatch.conf.*",
		"playwright.config.*",
		"eslint.config.*",
		"./typed-router.d.ts"
	],
	"compilerOptions": {
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node"]
	}
}