{
	"name": "garage-webadmin",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "vite preview",
		"build-only": "vite build",
		"type-check": "vue-tsc --build",
		"lint": "oxlint . --fix",
		"lint:check": "oxlint .",
		"format": "oxfmt .",
		"format:check": "oxfmt . --check",
		"fix": "run-s format lint",
		"check": "run-s format:check lint:check",
		"generate:schema": "npx openapi-typescript garage-admin-v2.json -o ./src/api-schema.d.ts"
	},
	"dependencies": {
		"@oddbird/css-anchor-positioning": "^0.9.0",
		"@oddbird/popover-polyfill": "^0.6.1",
		"@phosphor-icons/vue": "^2.2.1",
		"dialog-closedby-polyfill": "^1.3.0",
		"invokers-polyfill": "^1.0.1",
		"openapi-fetch": "^0.17.0",
		"vue": "^3.5.30",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^24.10.9",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vue/tsconfig": "^0.9.0",
		"npm-run-all2": "^8.0.4",
		"openapi-typescript": "^7.13.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"postcss": "^8.5.8",
		"postcss-custom-media": "^12.0.1",
		"postcss-design-token-utils": "^3.0.1",
		"typescript": "~5.9.3",
		"vite": "beta",
		"vite-plugin-magical-svg": "^1.9.0",
		"vite-plugin-vue-devtools": "^8.1.0",
		"vite-svg-loader": "^5.1.1",
		"vue-tsc": "^3.2.6",
		"whatwg-fetch": "^3.6.20"
	},
	"engines": {
		"node": "^24.14.0 || >=24.14.0"
	}
}